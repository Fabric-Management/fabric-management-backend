#!/bin/bash
# =============================================================================
# PRE-COMMIT HOOK: Code Quality & Migration-Entity Consistency
# =============================================================================
# - Java: format check (fmt:check) when .java files are staged
# - Migration/Entity: consistency checks when SQL or entity files are staged
#
# Last Updated: 2025-01-28

set -euo pipefail

# Colors
readonly RED='\033[0;31m'
readonly YELLOW='\033[1;33m'
readonly GREEN='\033[0;32m'
readonly NC='\033[0m'

# Project root (git repo root)
PROJECT_ROOT="$(git rev-parse --show-toplevel)"
readonly PROJECT_ROOT

# Ensure JAVA_HOME for Maven (prefer Java 21 for project compatibility)
if [ -z "${JAVA_HOME:-}" ]; then
    if [ -d /usr/local/opt/openjdk@21 ]; then
        export JAVA_HOME=/usr/local/opt/openjdk@21
    elif [ -d /opt/homebrew/opt/openjdk@21 ]; then
        export JAVA_HOME=/opt/homebrew/opt/openjdk@21
    elif [ -d /usr/local/opt/openjdk ]; then
        export JAVA_HOME=/usr/local/opt/openjdk
    elif [ -d /opt/homebrew/opt/openjdk ]; then
        export JAVA_HOME=/opt/homebrew/opt/openjdk
    fi
fi

# Use Maven wrapper if available, else mvn
MVN_CMD="mvn"
if [ -x "${PROJECT_ROOT}/mvnw" ]; then
    MVN_CMD="${PROJECT_ROOT}/mvnw"
fi

# Get staged files
readonly STAGED_JAVA=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.java$' || true)
readonly STAGED_MIGRATIONS=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'db/migration/.*\.sql$' || true)
readonly STAGED_ENTITIES=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'src/main/java/.*/domain/.*\.java$' || true)

# -----------------------------------------------------------------------------
# 1. Java format check (Google Java Format) - only when .java files staged
# -----------------------------------------------------------------------------
if [ -n "$STAGED_JAVA" ]; then
    echo -e "${YELLOW}🔍 Checking Java format (Google Java Format)...${NC}"
    if ! (cd "${PROJECT_ROOT}" && "${MVN_CMD}" -q fmt:check); then
        echo -e "${RED}❌ Format check failed. Some .java files are not formatted.${NC}"
        echo -e "${YELLOW}   Run: make format   or   ./mvnw fmt:format${NC}"
        echo -e "${YELLOW}   Then stage the changes and commit again.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✅ Java format OK${NC}"
    echo ""
fi

# Check if migrations are staged
if [ -n "$STAGED_MIGRATIONS" ]; then
    echo -e "${YELLOW}⚠️  Migration files staged:${NC}"
    echo "$STAGED_MIGRATIONS" | sed 's/^/  - /'
    echo ""
    echo -e "${YELLOW}📋 Checklist before committing:${NC}"
    echo "  ✓ Does migration CREATE TABLE match entity @Table schema/name?"
    echo "  ✓ Are all NOT NULL columns present in entity?"
    echo "  ✓ Are all entity @Column fields present in migration?"
    echo "  ✓ Are foreign keys correctly defined in both?"
    echo ""
    echo -e "${YELLOW}💡 Tip: Run 'make show-tables TABLES=\"table_name\"' to verify${NC}"
    echo ""
fi

# Check if entities are staged
if [ -n "$STAGED_ENTITIES" ]; then
    echo -e "${YELLOW}⚠️  Entity files staged:${NC}"
    echo "$STAGED_ENTITIES" | sed 's/^/  - /'
    echo ""
    echo -e "${YELLOW}📋 Checklist before committing:${NC}"
    echo "  ✓ Does entity @Table match migration CREATE TABLE?"
    echo "  ✓ Are all @Column fields present in migration?"
    echo "  ✓ Are nullable constraints consistent?"
    echo "  ✓ Are foreign key relationships defined in migration?"
    echo ""
fi

# If both migrations and entities are staged, warn about potential issues
if [ -n "$STAGED_MIGRATIONS" ] && [ -n "$STAGED_ENTITIES" ]; then
    echo -e "${GREEN}✅ Both migrations and entities staged - good!${NC}"
    echo -e "${YELLOW}⚠️  Double-check schema consistency before committing.${NC}"
    echo ""
fi

# Check for common mistakes
ERRORS=0

# Check migration files for common issues
for file in $STAGED_MIGRATIONS; do
    # Check for missing IF NOT EXISTS in CREATE TABLE
    if grep -q "CREATE TABLE[^I]" "$file" 2>/dev/null; then
        if ! grep -q "CREATE TABLE IF NOT EXISTS" "$file" 2>/dev/null; then
            echo -e "${RED}❌ $file: Missing 'IF NOT EXISTS' in CREATE TABLE${NC}"
            ERRORS=$((ERRORS + 1))
        fi
    fi
    
    # Check for missing IF NOT EXISTS in CREATE INDEX
    if grep -q "CREATE INDEX[^I]" "$file" 2>/dev/null; then
        if ! grep -q "CREATE INDEX IF NOT EXISTS" "$file" 2>/dev/null; then
            echo -e "${YELLOW}⚠️  $file: Consider adding 'IF NOT EXISTS' to CREATE INDEX${NC}"
        fi
    fi
done

# Final check
if [ $ERRORS -gt 0 ]; then
    echo ""
    echo -e "${RED}❌ Found $ERRORS error(s). Please fix before committing.${NC}"
    echo -e "${YELLOW}💡 Use 'git commit --no-verify' to skip (not recommended)${NC}"
    exit 1
fi

exit 0

